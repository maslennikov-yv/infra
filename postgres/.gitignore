# Артефакты сервиса (генерируются через make, не коммитятся)
#
# - `images/*.tar` создаётся командами:
#   - из корня: `make images-save ENV=<env> [SERVICE=postgres]`
#   - из директории сервиса: `make images-save ENV=<env>`
images/*.tar

# Директория с бэкапами БД (содержат дампы с возможными секретами)
backups/
*.sql.gz
*.sql

# Локальные values с секретами (если создаются вручную)
values-*-local.yaml

# Временные файлы
*.swp
*.swo
*~

