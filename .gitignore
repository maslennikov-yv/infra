# Корневой .gitignore — только общие для репозитория правила.
# Артефакты конкретных сервисов (например `images/*.tar`, бэкапы) игнорируются
# в `.gitignore` внутри соответствующего сервиса.

# Kubeconfig (локальные файлы окружений, содержат доступы)
# Создаются/обновляются командами:
# - `make env-new ENV=<name>` (создаёт плейсхолдер)
# - `make kubeconfig-fetch ENV=<name> SSH_HOST=... SSH_KEY=...` (скачивает реальный kubeconfig)
k8s/config/*
!k8s/config/README.md

# Локальные overrides окружений (SSH_HOST/SSH_KEY/KUBECONFIG/REGISTRY и т.п.)
# Создаются командой: `make env-new ENV=<name>`
environments/*.mk
!environments/*.yaml
# Бэкапы secrets/configmaps из кластера (make env-backup)
environments/backups/

# Per-app бэкапы (make app-backup APP=… ENV=…): apps/backups/<ENV>/<APP>/<service>/…
apps/backups/

# apps/.tmp — merged config приложений (apps-config-merge APP=… ENV=…),
# подаётся в Makefile.infra через APP_CONFIG для рендера values.yaml.gotmpl.
apps/.tmp/

# Docker tar-образы приложений (make app-image-save APP=… ENV=…)
apps/images/

# Секреты и чувствительные данные
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
secrets/
credentials/
values-*-local.yaml
*.tfstate
*.tfstate.*
terraform.tfvars
!terraform.tfvars.example
*.kubeconfig

# Per-env values overlay для helmfile (см. helmfile.yaml.gotmpl, optional: true).
# Реальные публичные hostname'ы, личные домены/email'ы для cert-manager,
# IP-allowlist'ы и другие env-specific данные, которые не должны попадать
# в публичный репозиторий. См. minio/README.md (раздел про hostname).
**/values-*.local.yaml

# Temporary files
*.swp
*.swo
*~
.DS_Store
*.tmp
*.log
*.bak
*.cache

# Node (infra TUI / @clack/prompts)
node_modules/

# Python (scripts/lib/*.py — кэш импорта)
__pycache__/
*.pyc

# IDE
.tools/
.vscode/
.idea/
*.iml
*.code-workspace
.project
.classpath
.settings/

# apps/registry.yaml — локальный реестр приложений окружения (содержит реальные имена/ns),
# не коммитим. В git только `apps/registry.yaml.example` как шаблон.
apps/registry.yaml

# apps/conf — opt-in inclusion: только _example/ и зашифрованные *.enc.yaml в git;
# plain *.yaml/*.yml и вся структура env-подкаталогов — локально (gitignored).
# Структура: apps/conf/<APP>/<ENV>/*.yaml (env-specific).
# Порядок правил критичен (последнее совпадение побеждает):
#   1. игнорируем apps/conf/*
#   2. разрешаем директории <APP>/ и <APP>/<ENV>/
#   3. игнорируем содержимое apps/conf/<APP>/<ENV>/*
#   4. разрешаем _example/** и зашифрованные *.enc.yaml на любом уровне
apps/conf/*
!apps/conf/_example/
!apps/conf/*/
apps/conf/*/*
!apps/conf/_example/**
!apps/conf/*/*/
apps/conf/*/*/*
!apps/conf/*/*/*.enc.yaml
!apps/conf/*/*/*.enc.yml
# Временные файлы backup-verify localize
apps/conf/*/*/*.localize.bak

# Клоны исходников приложений (git clone в apps/src/<name>) — не коммитим
apps/src/**
!apps/src/.gitkeep

# k8s-port-expose: per-env конфиг локально (содержит ns/svc:port пробросы — не секретно, но env-specific).
# Шаблон ports.example.yaml — в git. ports-<env>.yaml создаётся по make env-new.
k8s-port-expose/ports-*.yaml
!k8s-port-expose/ports.example.yaml

# backup-verify reports (фингерпринты, diff, restore-логи на admin-машине).
# Содержат структурные снимки prod (имена БД/таблиц/топиков/bucket'ов/queues) — секретно.
verify-reports/

# Backups, которые localize.sh оставляет рядом с apps/conf — не коммитим.
apps/conf/*/*.localize.bak

# Examples (reference implementations, not part of infrastructure)
examples/